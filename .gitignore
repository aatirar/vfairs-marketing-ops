# ─── Credentials (NEVER commit these) ───────────────────────────────────────
.config/
*.yaml
*.json
!package.json
!package-lock.json
!pyproject.toml
!.claude/skills/**/*.json
!.claude/agents/**/*.json
!scripts/workflows/*.json
!setup/credentials-template/*.yaml

# ─── Env files ────────────────────────────────────────────────────────────────
.env
*.env
!.env.example

# ─── Claude Code per-user settings ──────────────────────────────────────────
.claude/settings.local.json
.claude/agent-memory/

# ─── MCP server local state ─────────────────────────────────────────────────
mcp-servers/**/.venv/
mcp-servers/**/token_cache/
mcp-servers/**/*.pyc
mcp-servers/**/__pycache__/

# ─── Generated .mcp.json (each person has their own paths) ──────────────────
.mcp.json

# ─── Real business data (synced from shared Drive, never committed) ─────────
data/**
!data/.gitkeep
!data/README.md

# ─── Generated outputs (folder kept, contents ignored) ──────────────────────
outputs/**
!outputs/.gitkeep
!outputs/README.md

# ─── Per-marketer scratch space ─────────────────────────────────────────────
workspaces/**
!workspaces/.gitkeep
!workspaces/README.md

# ─── Node ────────────────────────────────────────────────────────────────────
node_modules/
scripts/**/node_modules/
src/**/node_modules/

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ─── OS files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
