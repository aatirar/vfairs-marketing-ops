# vFairs Marketing OS — environment template
#
# 1. Copy this file to .env (which is gitignored)
# 2. Open the team vault entry "vFairs Marketing OS .env values"
# 3. Paste each value below
# 4. Save
#
# Never commit .env. Never share it via Slack/email. Send people to the vault.

# ─── Shared (read-only) — from team vault ─────────────────────────────────

# HubSpot read-only private app
HUBSPOT_ACCESS_TOKEN=

# Google Ads (shared marketing-bot@vfairs.com refresh token)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# GA4 (the service account JSON in .config/ handles auth; this is just the property)
GA4_PROPERTY_ID=269289033

# Gong (shared marketing read-only)
GONG_API_KEY=
GONG_API_SECRET=

# SEO + competitive intel
AHREFS_API_KEY=
SEMRUSH_API_KEY=
APIFY_API_KEY=
TAVILY_API_KEY=

# Outbound + email
SMARTLEAD_API_KEY=

# Generative
GEMINI_API_KEY=

# Optional — only if you use LinkedIn-fetching content skills
RAPIDAPI_KEY=

# ─── Personal (per marketer) ──────────────────────────────────────────────

# Slack user token — see ONBOARDING.md Step 4c
# Optional. Skip if you don't use /morning-report, /slack-tasks, /slack-campaigns, /audit-debt
SLACK_USER_TOKEN=

# Google Workspace OAuth client (shared from vault, used to generate YOUR personal Gmail/Calendar token)
# After setting these, run: python scripts/utils/generate-workspace-token.py your-name@vfairs.com
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Optional overrides ───────────────────────────────────────────────────

# Override the default Google service account path
# GOOGLE_APPLICATION_CREDENTIALS=.config/google-credentials.json

# Override the default Google Cloud project ID
# GOOGLE_PROJECT_ID=gdrive-mcp-456412
